#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# alma-record — Grava audio e envia transcrição para o ALMA
# ============================================================================
#
# INSTALACAO (uma vez):
#   pkg install jq curl termux-api
#   cp alma-record $PREFIX/bin/alma-record && chmod +x $PREFIX/bin/alma-record
#   # Configurar ~/.alma-env (ver alma-send)
#
# USO:
#   alma-record                          # grava, transcreve, envia
#   alma-record -s 15                    # grava 15 segundos
#   alma-record -t "Reflexao noturna"    # com titulo
#   alma-record -c fe -g "jesus,noite"   # com categoria e tags
#   alma-record -k                       # mantem o audio apos enviar
#
# O QUE ACONTECE:
#   1. Grava audio pelo microfone do celular (default: 30s, para com Ctrl+C)
#   2. Transcreve usando o speech engine do Android (Google, gratis)
#   3. Envia a transcricao para o banco do ALMA via /api/ingest
#   4. Apaga o audio temporario (a menos que use -k)
#
# ============================================================================

set -e

# Config
ENV_FILE="$HOME/.alma-env"
if [ -f "$ENV_FILE" ]; then
  source "$ENV_FILE"
fi

ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
ALMA_USER="${ALMA_USER:-}"
ALMA_PASS="${ALMA_PASS:-}"

# Defaults
DURATION=30
TITLE=""
CATEGORY="memorias_pessoais"
TAGS=""
SOURCE="termux_audio"
KEEP_AUDIO=0
AUDIO_FILE="$HOME/alma_capture_$(date +%Y%m%d_%H%M%S).m4a"

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    -s) DURATION="$2"; shift 2 ;;
    -t) TITLE="$2"; shift 2 ;;
    -c) CATEGORY="$2"; shift 2 ;;
    -g) TAGS="$2"; shift 2 ;;
    -k) KEEP_AUDIO=1; shift ;;
    -h|--help)
      head -28 "$0" | grep -E '^\s*#' | sed 's/^# \?//'
      exit 0
      ;;
    *) shift ;;
  esac
done

# Validate
if [ -z "$ALMA_USER" ] || [ -z "$ALMA_PASS" ]; then
  echo "ERRO: Configure ~/.alma-env primeiro (ver alma-send -h)" >&2
  exit 1
fi

# ============================================================
# PASSO 1: Gravar audio
# ============================================================
echo ""
echo "=== ALMA Record ==="
echo "Gravando ${DURATION}s... Fale agora."
echo "(Ctrl+C para parar antes)"
echo ""

# Gravar via Termux:API
termux-microphone-record -l "$DURATION" -f "$AUDIO_FILE" 2>/dev/null

# Esperar a gravacao (com trap pra parar limpo)
RECORDING=1
trap 'RECORDING=0; termux-microphone-record -q 2>/dev/null; echo ""; echo "Gravacao parada."' INT

ELAPSED=0
while [ $RECORDING -eq 1 ] && [ $ELAPSED -lt $DURATION ]; do
  printf "\r  Gravando... %ds/%ds " "$ELAPSED" "$DURATION"
  sleep 1
  ELAPSED=$((ELAPSED + 1))
done

# Parar gravacao se nao parou
termux-microphone-record -q 2>/dev/null
trap - INT

echo ""

# Verificar se o audio foi criado
if [ ! -f "$AUDIO_FILE" ]; then
  echo "ERRO: Audio nao foi criado." >&2
  exit 1
fi

AUDIO_SIZE=$(stat -c%s "$AUDIO_FILE" 2>/dev/null || stat -f%z "$AUDIO_FILE" 2>/dev/null)
echo "Audio: $AUDIO_FILE ($AUDIO_SIZE bytes)"

# ============================================================
# PASSO 2: Transcrever
# ============================================================
echo ""
echo "Transcrevendo (via Android speech engine)..."

# Usar termux-speech-to-text (usa Google Speech do Android)
TRANSCRIPT=$(termux-speech-to-text 2>/dev/null || echo "")

if [ -z "$TRANSCRIPT" ]; then
  echo ""
  echo "Transcricao automatica falhou ou vazia."
  echo "Opcoes:"
  echo "  1) Digitar/colar o texto manualmente"
  echo "  2) Cancelar"
  echo ""
  read -p "Texto (ou Enter pra cancelar): " TRANSCRIPT

  if [ -z "$TRANSCRIPT" ]; then
    echo "Cancelado."
    [ $KEEP_AUDIO -eq 0 ] && rm -f "$AUDIO_FILE"
    exit 0
  fi
fi

CHAR_COUNT=${#TRANSCRIPT}
echo ""
echo "Transcricao ($CHAR_COUNT chars):"
echo "---"
echo "$TRANSCRIPT"
echo "---"
echo ""

# Confirmar
read -p "Enviar para o ALMA? [S/n] " CONFIRM
CONFIRM=${CONFIRM:-S}
if [[ ! "$CONFIRM" =~ ^[SsYy]$ ]]; then
  echo "Cancelado."
  [ $KEEP_AUDIO -eq 0 ] && rm -f "$AUDIO_FILE"
  exit 0
fi

# ============================================================
# PASSO 3: Enviar para o ALMA
# ============================================================
echo ""
echo "Autenticando..."

LOGIN_RESPONSE=$(curl -s -X POST "$ALMA_URL/api/auth" \
  -H "Content-Type: application/json" \
  -d "{\"action\":\"login\",\"username\":\"$ALMA_USER\",\"password\":\"$ALMA_PASS\"}")

TOKEN=$(echo "$LOGIN_RESPONSE" | jq -r '.token // empty')

if [ -z "$TOKEN" ]; then
  ERROR=$(echo "$LOGIN_RESPONSE" | jq -r '.error // "Erro desconhecido"')
  echo "ERRO: Login falhou — $ERROR" >&2
  exit 1
fi

# Build tags
TAGS_JSON="[\"$SOURCE\", \"audio_transcrito\"]"
if [ -n "$TAGS" ]; then
  EXTRA=$(echo "$TAGS" | tr ',' '\n' | jq -R . | jq -s .)
  TAGS_JSON=$(echo "[$EXTRA, [\"$SOURCE\", \"audio_transcrito\"]]" | jq -s 'flatten')
fi

# Auto title
if [ -z "$TITLE" ]; then
  DATE_STR=$(date +%Y-%m-%d\ %H:%M)
  PREVIEW=$(echo "$TRANSCRIPT" | head -c 50 | tr '\n' ' ')
  TITLE="Audio $DATE_STR — $PREVIEW..."
fi

CONTENT_JSON=$(echo "$TRANSCRIPT" | jq -Rs .)
TITLE_JSON=$(echo "$TITLE" | jq -Rs .)

echo "Enviando..."

INGEST_RESPONSE=$(curl -s -X POST "$ALMA_URL/api/ingest" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $TOKEN" \
  -d "{
    \"content\": $CONTENT_JSON,
    \"title\": $TITLE_JSON,
    \"category\": \"$CATEGORY\",
    \"tags\": $TAGS_JSON,
    \"source\": \"$SOURCE\"
  }")

SUCCESS=$(echo "$INGEST_RESPONSE" | jq -r '.success // empty')

if [ "$SUCCESS" = "true" ]; then
  CHUNKS=$(echo "$INGEST_RESPONSE" | jq -r '.chunks_created')
  echo ""
  echo "ALMA — Salvo!"
  echo "  Titulo: $TITLE"
  echo "  Chunks: $CHUNKS"
  echo "  Chars: $CHAR_COUNT"
  echo "  Categoria: $CATEGORY"
else
  ERROR=$(echo "$INGEST_RESPONSE" | jq -r '.error // "Erro desconhecido"')
  echo "ERRO: $ERROR" >&2
fi

# Limpar audio
if [ $KEEP_AUDIO -eq 0 ]; then
  rm -f "$AUDIO_FILE"
  echo "  Audio temporario removido."
else
  echo "  Audio mantido: $AUDIO_FILE"
fi
