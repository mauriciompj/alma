#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# alma-quick — Captura de voz rapida e silenciosa para o ALMA
# ============================================================================
# Versao automatica (sem confirmacao) para uso via:
#   - Termux:Widget (1 toque na home screen)
#   - Atalho rapido
#
# Fluxo: abre dialog → mic do teclado → transcreve → envia → notifica → fim
#
# SETUP:
#   pkg install jq curl termux-api
#   cp alma-quick $PREFIX/bin/ && chmod +x $PREFIX/bin/alma-quick
#   cp alma-lib.sh $PREFIX/bin/ && chmod +x $PREFIX/bin/alma-lib.sh
#
#   # Para Termux:Widget (1 toque):
#   mkdir -p ~/.shortcuts
#   ln -s $PREFIX/bin/alma-quick ~/.shortcuts/ALMA
#
# USO:
#   alma-quick                    # categoria padrao (memorias_pessoais)
#   alma-quick fe                 # categoria especifica
#   alma-quick valores "titulo"   # categoria + titulo
#
# ============================================================================

set -e

# Load shared library
source "$(dirname "$0")/alma-lib.sh" 2>/dev/null || source "$PREFIX/bin/alma-lib.sh" 2>/dev/null || {
  echo "ERRO: alma-lib.sh nao encontrado" >&2; exit 1
}

alma_load_config
alma_check_creds || exit 1

CATEGORY="${1:-memorias_pessoais}"
CUSTOM_TITLE="${2:-}"

# Notificar que esta ouvindo
alma_toast "ALMA ouvindo..." middle
alma_vibrate 200

# Capturar via dialog nativo do Android
DIALOG_RESULT=$(termux-dialog text -t "ALMA — Fale ou digite" -i "Toque no mic do teclado e fale" 2>/dev/null || echo "{}")
TEXT=$(echo "$DIALOG_RESULT" | jq -r '.text // empty')

if [ -z "$TEXT" ]; then
  alma_toast "ALMA: Nada capturado"
  alma_vibrate 100
  exit 0
fi

CHAR_COUNT=${#TEXT}
alma_toast "ALMA: ${CHAR_COUNT} chars. Enviando..." middle

# Gerar titulo
if [ -n "$CUSTOM_TITLE" ]; then
  TITLE="$CUSTOM_TITLE"
else
  TITLE=$(alma_auto_title "$TEXT" "Voz")
fi

# Enviar via alma-lib
if RESP=$(alma_ingest "$TEXT" "$TITLE" "$CATEGORY" '["termux_voice","voz","quick"]' "termux_quick" 2>&1); then
  CHUNKS=$(echo "$RESP" | jq -r '.chunks_created')
  alma_vibrate 200
  alma_toast "ALMA salvo! ${CHAR_COUNT} chars (${CHUNKS} chunks)"
  alma_notify "ALMA — Memoria salva" "$(echo "$TEXT" | head -c 50)..."  "alma_capture"
else
  ERROR=$(echo "$RESP" | jq -r '.error // empty' 2>/dev/null)
  if [ -z "$ERROR" ]; then
    ERROR=$(echo "$RESP" | tail -n 1)
  fi
  if [ -z "$ERROR" ]; then
    ERROR="erro"
  fi
  alma_toast "ALMA erro: $ERROR"
  alma_vibrate 300
  exit 1
fi
