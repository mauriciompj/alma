#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# termux-url-opener — Recebe texto/links compartilhados de qualquer app
# ============================================================================
# Quando voce toca "Compartilhar" em qualquer app e escolhe Termux,
# este script recebe o texto e envia pro ALMA.
#
# INSTALACAO:
#   mkdir -p ~/bin
#   cp termux-url-opener ~/bin/termux-url-opener
#   cp alma-lib.sh ~/bin/ && chmod +x ~/bin/alma-lib.sh
#   chmod +x ~/bin/termux-url-opener
# ============================================================================

set -e

source "$(dirname "$0")/alma-lib.sh" 2>/dev/null || source "$PREFIX/bin/alma-lib.sh" 2>/dev/null || source "$HOME/bin/alma-lib.sh" 2>/dev/null || {
  ENV_FILE="$HOME/.alma-env"; [ -f "$ENV_FILE" ] && source "$ENV_FILE"
  ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
}

alma_load_config 2>/dev/null
alma_check_creds 2>/dev/null || exit 1

SHARED="$1"
if [ -z "$SHARED" ]; then
  alma_toast "ALMA: Nada recebido"
  exit 0
fi

CHAR_COUNT=${#SHARED}

if [[ "$SHARED" =~ ^https?:// ]]; then
  alma_toast "ALMA: URL recebida ($CHAR_COUNT chars)" middle
else
  alma_toast "ALMA: Texto recebido ($CHAR_COUNT chars)" middle
fi

# Escolher categoria
DIALOG=$(termux-dialog sheet -t "ALMA — Salvar memoria" -v "Memorias pessoais,Valores,Fe,Paternidade,Relacionamentos,Familia,Profissao,Trauma,Identidade,Amor,Legado ALMA,Tecnologia/IA,Psicologia,Cancelar" 2>/dev/null || echo '{"index":-1}')
INDEX=$(echo "$DIALOG" | jq -r '.index // -1')

case "$INDEX" in
  0) CATEGORY="memorias_pessoais" ;;
  1) CATEGORY="valores" ;;
  2) CATEGORY="fe" ;;
  3) CATEGORY="paternidade" ;;
  4) CATEGORY="relacionamentos" ;;
  5) CATEGORY="familia" ;;
  6) CATEGORY="profissao" ;;
  7) CATEGORY="trauma" ;;
  8) CATEGORY="identidade" ;;
  9) CATEGORY="amor" ;;
  10) CATEGORY="legado_alma" ;;
  11) CATEGORY="tecnologia_ia" ;;
  12) CATEGORY="psicologia" ;;
  *) alma_toast "Cancelado."; exit 0 ;;
esac

# Titulo opcional
TITLE_DIALOG=$(termux-dialog text -t "Titulo (opcional)" -i "" 2>/dev/null || echo '{"text":""}')
CUSTOM_TITLE=$(echo "$TITLE_DIALOG" | jq -r '.text // empty')

alma_toast "ALMA: Enviando..." middle

# Enviar via alma-send (handles auth, retry)
if [ -n "$CUSTOM_TITLE" ]; then
  echo "$SHARED" | alma-send -t "$CUSTOM_TITLE" -c "$CATEGORY" -s "android_share" -g "$CATEGORY,compartilhado"
else
  echo "$SHARED" | alma-send -c "$CATEGORY" -s "android_share" -g "$CATEGORY,compartilhado"
fi
