#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# termux-file-editor — Android Share → Termux → ALMA
# ============================================================================
# When you share a file to Termux (Share → Termux → EDIT), this script
# converts the file to plain text and sends it to ALMA via alma-send.
#
# Supported formats:
#   .txt, .md, .csv, .json  — sent directly
#   .pdf                     — converted via pdftotext
#   .docx, .doc, .odt, .rtf — converted via pandoc
#
# INSTALL:
#   cp termux-file-editor ~/bin/termux-file-editor
#   chmod +x ~/bin/termux-file-editor
#   pkg install pandoc poppler  # for docx/pdf support
# ============================================================================

FILE="$1"
if [ -z "$FILE" ]; then exit 1; fi
EXT="${FILE##*.}"
EXT=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')
case "$EXT" in
txt|md|csv|json) alma-send -f "$FILE" ;;
pdf)
  if ! command -v pdftotext &>/dev/null; then
    termux-toast "pdftotext nao instalado. Rode: pkg install poppler"
    exit 1
  fi
  pdftotext "$FILE" - | alma-send -t "$(basename "$FILE")" ;;
docx|doc|odt|rtf)
  if ! command -v pandoc &>/dev/null; then
    termux-toast "pandoc nao instalado. Rode: pkg install pandoc"
    exit 1
  fi
  pandoc "$FILE" -t plain | alma-send -t "$(basename "$FILE")" ;;
*) termux-toast "Formato .$EXT nao suportado" ;;
esac
