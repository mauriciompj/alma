#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# termux-file-receiver — Recebe arquivos compartilhados de qualquer app
# ============================================================================
# Quando voce compartilha um arquivo (PDF, DOCX, TXT, audio) e escolhe
# Termux, este script extrai o texto e envia pro ALMA.
#
# INSTALACAO:
#   pkg install poppler    # pra PDF
#   pip install python-docx  # pra DOCX (opcional)
#   mkdir -p ~/bin
#   cp termux-file-receiver ~/bin/termux-file-receiver
#   chmod +x ~/bin/termux-file-receiver
#
# FORMATOS SUPORTADOS:
#   .txt .md .csv .json  — texto direto
#   .pdf                 — extrai texto via pdftotext
#   .docx .doc .odt .rtf — extrai texto via pandoc/python-docx
#   .m4a .ogg .opus .mp3 — audio (transcreve via Gemini ou fallback manual)
#
# ============================================================================

set -e

# Load shared library
source "$(dirname "$0")/alma-lib.sh" 2>/dev/null || source "$PREFIX/bin/alma-lib.sh" 2>/dev/null || source "$HOME/bin/alma-lib.sh" 2>/dev/null || {
  ENV_FILE="$HOME/.alma-env"
  [ -f "$ENV_FILE" ] && source "$ENV_FILE"
  ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
}

alma_load_config 2>/dev/null
ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
ALMA_USER="${ALMA_USER:-}"
ALMA_PASS="${ALMA_PASS:-}"

# O arquivo compartilhado vem como argumento $1
FILE="$1"

if [ -z "$FILE" ] || [ ! -f "$FILE" ]; then
  alma_toast "ALMA: Arquivo nao encontrado"
  exit 1
fi

FILENAME=$(basename "$FILE")
EXT="${FILENAME##*.}"
EXT=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')
FILESIZE=$(stat -c%s "$FILE" 2>/dev/null || stat -f%z "$FILE" 2>/dev/null || echo "0")

alma_toast "ALMA: Processando $FILENAME ($FILESIZE bytes)" middle

# ============================================================
# Extrair texto baseado no formato
# ============================================================
TEXT=""

case "$EXT" in
  txt|md|csv|json|log)
    TEXT=$(cat "$FILE")
    ;;

  pdf)
    if command -v pdftotext &>/dev/null; then
      TEXT=$(pdftotext "$FILE" - 2>/dev/null)
    else
      alma_toast "ALMA: Instale poppler (pkg install poppler) pra processar PDF"
      exit 1
    fi
    ;;

  docx|doc|odt|rtf)
    if command -v pandoc &>/dev/null; then
      TEXT=$(pandoc "$FILE" -t plain 2>/dev/null)
    elif command -v python3 &>/dev/null && python3 -c "import docx" 2>/dev/null; then
      TEXT=$(python3 -c "
import docx, sys
doc = docx.Document(sys.argv[1])
print('\n'.join([p.text for p in doc.paragraphs]))
" "$FILE" 2>/dev/null)
    else
      # Fallback: extrair XML interno do DOCX (eh um ZIP)
      TEXT=$(unzip -p "$FILE" word/document.xml 2>/dev/null | sed 's/<[^>]*>//g' | tr -s ' \n' || echo "")
      if [ -z "$TEXT" ]; then
        alma_toast "ALMA: Nao consegui extrair texto do arquivo"
        exit 1
      fi
    fi
    ;;

  m4a|ogg|opus|mp3|wav|aac)
    alma_toast "ALMA: Transcrevendo audio..." middle
    TEXT=$(alma_transcribe_audio "$FILE" 2>${TMPDIR:-/tmp}/alma_whisper_err)
    if [ -z "$TEXT" ]; then
      ERR_MSG=$(cat ${TMPDIR:-/tmp}/alma_whisper_err 2>/dev/null)
      alma_toast "Transcricao falhou. Digitando manual..." middle
      DIALOG=$(termux-dialog text -t "ALMA — Transcreva o audio" \
        -i "${ERR_MSG:-Gemini indisponivel. Digite o conteudo}" 2>/dev/null || echo '{"text":""}')
      TEXT=$(echo "$DIALOG" | jq -r '.text // empty')
      if [ -z "$TEXT" ]; then
        alma_toast "ALMA: Transcricao vazia, cancelado"
        exit 0
      fi
    fi
    TEXT="[Audio transcrito: $FILENAME] $TEXT"
    ;;

  jpg|jpeg|png|gif|webp)
    alma_toast "ALMA: Analisando imagem..." middle
    TEXT=$(alma_describe_image "$FILE" 2>${TMPDIR:-/tmp}/alma_vision_err)
    if [ -z "$TEXT" ]; then
      ERR_MSG=$(cat ${TMPDIR:-/tmp}/alma_vision_err 2>/dev/null)
      alma_toast "Analise falhou. Descrevendo manual..." middle
      DIALOG=$(termux-dialog text -t "ALMA — Descreva a imagem" \
        -i "${ERR_MSG:-Claude Vision indisponivel. Descreva a imagem}" 2>/dev/null || echo '{"text":""}')
      TEXT=$(echo "$DIALOG" | jq -r '.text // empty')
      if [ -z "$TEXT" ]; then
        alma_toast "ALMA: Descricao vazia, cancelado"
        exit 0
      fi
    fi
    TEXT="[Imagem: $FILENAME] $TEXT"
    ;;

  *)
    alma_toast "ALMA: Formato .$EXT nao suportado"
    exit 1
    ;;
esac

if [ -z "$TEXT" ]; then
  alma_toast "ALMA: Nenhum texto extraido de $FILENAME"
  exit 1
fi

CHAR_COUNT=${#TEXT}
alma_toast "ALMA: $CHAR_COUNT chars extraidos. Escolha categoria..." middle

# ============================================================
# Categoria
# ============================================================
CATEGORY=$(alma_pick_category "ALMA — Categoria") || {
  alma_toast "Cancelado."
  exit 0
}

# ============================================================
# Enviar via alma-send (handles auth, retry, chunking)
# ============================================================
alma_toast "ALMA: Enviando..." middle

case "$EXT" in
  m4a|ogg|opus|mp3|wav|aac)
    printf '%s' "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_audio" -g "$EXT,audio,transcricao_gemini"
    ;;
  jpg|jpeg|png|gif|webp)
    printf '%s' "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_imagem" -g "$EXT,imagem,descricao_claude"
    ;;
  *)
    printf '%s' "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_file" -g "$EXT,arquivo"
    ;;
esac
