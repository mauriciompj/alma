#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# termux-file-receiver — Recebe arquivos compartilhados de qualquer app
# ============================================================================
# Quando voce compartilha um arquivo (PDF, DOCX, TXT, audio) e escolhe
# Termux, este script extrai o texto e envia pro ALMA.
#
# INSTALACAO:
#   pkg install poppler    # pra PDF
#   pip install python-docx  # pra DOCX (opcional)
#   mkdir -p ~/bin
#   cp termux-file-receiver ~/bin/termux-file-receiver
#   chmod +x ~/bin/termux-file-receiver
#
# FORMATOS SUPORTADOS:
#   .txt .md .csv .json  — texto direto
#   .pdf                 — extrai texto via pdftotext
#   .docx                — extrai texto via python-docx
#   .m4a .ogg .opus .mp3 — audio (transcreve via mic ou salva referencia)
#
# ============================================================================

set -e

# Load shared library
source "$(dirname "$0")/alma-lib.sh" 2>/dev/null || source "$PREFIX/bin/alma-lib.sh" 2>/dev/null || source "$HOME/bin/alma-lib.sh" 2>/dev/null || {
  ENV_FILE="$HOME/.alma-env"
  [ -f "$ENV_FILE" ] && source "$ENV_FILE"
  ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
}

alma_load_config 2>/dev/null
ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
ALMA_USER="${ALMA_USER:-}"
ALMA_PASS="${ALMA_PASS:-}"

# O arquivo compartilhado vem como argumento $1
FILE="$1"

if [ -z "$FILE" ] || [ ! -f "$FILE" ]; then
  termux-toast -g bottom "ALMA: Arquivo nao encontrado"
  exit 1
fi

FILENAME=$(basename "$FILE")
EXT="${FILENAME##*.}"
EXT=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')
FILESIZE=$(stat -c%s "$FILE" 2>/dev/null || stat -f%z "$FILE" 2>/dev/null || echo "0")

termux-toast -g middle "ALMA: Processando $FILENAME ($FILESIZE bytes)"

# ============================================================
# Extrair texto baseado no formato
# ============================================================
TEXT=""

case "$EXT" in
  txt|md|csv|json|log)
    TEXT=$(cat "$FILE")
    ;;

  pdf)
    if command -v pdftotext &>/dev/null; then
      TEXT=$(pdftotext "$FILE" - 2>/dev/null)
    else
      termux-toast -g bottom "ALMA: Instale poppler (pkg install poppler) pra processar PDF"
      exit 1
    fi
    ;;

  docx)
    if command -v python3 &>/dev/null && python3 -c "import docx" 2>/dev/null; then
      TEXT=$(python3 -c "
import docx
doc = docx.Document('$FILE')
for p in doc.paragraphs:
    print(p.text)
" 2>/dev/null)
    else
      # Fallback: extrair XML interno do DOCX (eh um ZIP)
      TEXT=$(unzip -p "$FILE" word/document.xml 2>/dev/null | sed 's/<[^>]*>//g' | tr -s ' \n' || echo "")
      if [ -z "$TEXT" ]; then
        termux-toast -g bottom "ALMA: Nao consegui extrair texto do DOCX"
        exit 1
      fi
    fi
    ;;

  m4a|ogg|opus|mp3|wav|aac)
    termux-toast -g middle "ALMA: Transcrevendo audio..."
    TEXT=$(alma_transcribe_audio "$FILE" 2>/tmp/alma_whisper_err)
    if [ -z "$TEXT" ]; then
      ERR_MSG=$(cat /tmp/alma_whisper_err 2>/dev/null)
      termux-toast -g middle "Transcricao falhou. Digitando manual..."
      DIALOG=$(termux-dialog text -t "ALMA — Transcreva o audio" \
        -i "${ERR_MSG:-Whisper indisponivel. Digite o conteudo}" 2>/dev/null || echo '{"text":""}')
      TEXT=$(echo "$DIALOG" | jq -r '.text // empty')
      if [ -z "$TEXT" ]; then
        termux-toast -g bottom "ALMA: Transcricao vazia, cancelado"
        exit 0
      fi
    fi
    TEXT="[Audio transcrito: $FILENAME] $TEXT"
    ;;

  jpg|jpeg|png|gif|webp)
    termux-toast -g middle "ALMA: Analisando imagem..."
    TEXT=$(alma_describe_image "$FILE" 2>/tmp/alma_vision_err)
    if [ -z "$TEXT" ]; then
      ERR_MSG=$(cat /tmp/alma_vision_err 2>/dev/null)
      termux-toast -g middle "Analise falhou. Descrevendo manual..."
      DIALOG=$(termux-dialog text -t "ALMA — Descreva a imagem" \
        -i "${ERR_MSG:-Claude Vision indisponivel. Descreva a imagem}" 2>/dev/null || echo '{"text":""}')
      TEXT=$(echo "$DIALOG" | jq -r '.text // empty')
      if [ -z "$TEXT" ]; then
        termux-toast -g bottom "ALMA: Descricao vazia, cancelado"
        exit 0
      fi
    fi
    TEXT="[Imagem: $FILENAME] $TEXT"
    ;;

  *)
    termux-toast -g bottom "ALMA: Formato .$EXT nao suportado"
    exit 1
    ;;
esac

if [ -z "$TEXT" ]; then
  termux-toast -g bottom "ALMA: Nenhum texto extraido de $FILENAME"
  exit 1
fi

CHAR_COUNT=${#TEXT}
termux-toast -g middle "ALMA: $CHAR_COUNT chars extraidos. Escolha categoria..."

# ============================================================
# Categoria
# ============================================================
DIALOG=$(termux-dialog sheet -t "ALMA — Categoria" -v "Memorias pessoais,Valores,Fe,Paternidade,Relacionamentos,Familia,Profissao,Trauma,Identidade,Amor,Legado ALMA,Tecnologia/IA,Psicologia,Cancelar" 2>/dev/null || echo '{"index":-1}')
INDEX=$(echo "$DIALOG" | jq -r '.index // -1')

case "$INDEX" in
  0) CATEGORY="memorias_pessoais" ;;
  1) CATEGORY="valores" ;;
  2) CATEGORY="fe" ;;
  3) CATEGORY="paternidade" ;;
  4) CATEGORY="relacionamentos" ;;
  5) CATEGORY="familia" ;;
  6) CATEGORY="profissao" ;;
  7) CATEGORY="trauma" ;;
  8) CATEGORY="identidade" ;;
  9) CATEGORY="amor" ;;
  10) CATEGORY="legado_alma" ;;
  11) CATEGORY="tecnologia_ia" ;;
  12) CATEGORY="psicologia" ;;
  *) termux-toast -g bottom "Cancelado."; exit 0 ;;
esac

# ============================================================
# Enviar via alma-send (handles auth, retry, chunking)
# ============================================================
termux-toast -g middle "ALMA: Enviando..."

case "$EXT" in
  m4a|ogg|opus|mp3|wav|aac)
    echo "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_audio" -g "$EXT,audio,transcricao_whisper"
    ;;
  jpg|jpeg|png|gif|webp)
    echo "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_imagem" -g "$EXT,imagem,descricao_claude"
    ;;
  *)
    echo "$TEXT" | alma-send -t "$FILENAME" -c "$CATEGORY" -s "android_share_file" -g "$EXT,arquivo"
    ;;
esac
