#!/data/data/com.termux/files/usr/bin/bash
# ============================================================================
# alma-send — Envia conteudo para o ALMA direto do Termux
# ============================================================================
#
# INSTALACAO:
#   1. Copie este arquivo para o Termux:
#      cp alma-send $PREFIX/bin/alma-send
#      chmod +x $PREFIX/bin/alma-send
#
#   2. Configure suas credenciais:
#      echo 'ALMA_URL=https://projeto-alma.netlify.app' >> ~/.alma-env
#      echo 'ALMA_USER=Mauricio' >> ~/.alma-env
#      echo 'ALMA_PASS=SuaSenha' >> ~/.alma-env
#
#   3. Instale dependencias:
#      pkg install jq curl
#
# USO:
#   alma-send "texto que quero salvar no ALMA"
#   alma-send -f arquivo.txt
#   alma-send -f conversa.md -t "Conversa com IA sobre fé"
#   alma-send -f documento.txt -c valores -g "fe,reflexao"
#   cat conversa.txt | alma-send
#   xclip -o | alma-send                    # cola do clipboard (Linux)
#   termux-clipboard-get | alma-send        # cola do clipboard (Termux)
#
# OPCOES:
#   -f <arquivo>     Envia arquivo (.txt, .md, .csv, .json)
#   -t <titulo>      Define titulo (senao gera automatico)
#   -c <categoria>   Define categoria (default: memorias_pessoais)
#   -g <tags>        Tags separadas por virgula
#   -s <source>      Identificador de origem (default: termux)
#   -d               Dry run — mostra o que enviaria sem enviar
#   -h               Ajuda
#
# EXEMPLOS RAPIDOS:
#   # Salvar reflexao rapida
#   alma-send "Hoje percebi que coragem nao e ausencia de medo"
#
#   # Salvar conversa colada do clipboard
#   termux-clipboard-get | alma-send -t "Conversa sobre paternidade"
#
#   # Salvar arquivo com categoria e tags
#   alma-send -f reflexao.md -c fe -g "jesus,oracao,noite"
#
# ============================================================================

set -e

# Carregar config
ENV_FILE="$HOME/.alma-env"
if [ -f "$ENV_FILE" ]; then
  source "$ENV_FILE"
fi

ALMA_URL="${ALMA_URL:-https://projeto-alma.netlify.app}"
ALMA_USER="${ALMA_USER:-}"
ALMA_PASS="${ALMA_PASS:-}"

# Defaults
FILE=""
TITLE=""
CATEGORY="memorias_pessoais"
TAGS=""
SOURCE="termux"
DRY_RUN=0
CONTENT=""

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    -f) FILE="$2"; shift 2 ;;
    -t) TITLE="$2"; shift 2 ;;
    -c) CATEGORY="$2"; shift 2 ;;
    -g) TAGS="$2"; shift 2 ;;
    -s) SOURCE="$2"; shift 2 ;;
    -d) DRY_RUN=1; shift ;;
    -h|--help)
      head -50 "$0" | grep -E '^\s*#' | sed 's/^# \?//'
      exit 0
      ;;
    *)
      # Positional argument = inline text
      CONTENT="$1"; shift ;;
  esac
done

# Read from stdin if no content and no file
if [ -z "$CONTENT" ] && [ -z "$FILE" ]; then
  if [ ! -t 0 ]; then
    CONTENT=$(cat)
  fi
fi

# Read from file
if [ -n "$FILE" ]; then
  if [ ! -f "$FILE" ]; then
    echo "ERRO: Arquivo nao encontrado: $FILE" >&2
    exit 1
  fi
  CONTENT=$(cat "$FILE")
  # Use filename as default title
  if [ -z "$TITLE" ]; then
    TITLE="$(basename "$FILE" | sed 's/\.[^.]*$//')"
  fi
fi

# Validate
if [ -z "$CONTENT" ]; then
  echo "ERRO: Nenhum conteudo. Use: alma-send \"texto\" ou alma-send -f arquivo.txt" >&2
  echo "      Ou: echo \"texto\" | alma-send" >&2
  exit 1
fi

if [ -z "$ALMA_USER" ] || [ -z "$ALMA_PASS" ]; then
  echo "ERRO: Configure ALMA_USER e ALMA_PASS em ~/.alma-env" >&2
  echo "  echo 'ALMA_USER=Mauricio' >> ~/.alma-env" >&2
  echo "  echo 'ALMA_PASS=SuaSenha' >> ~/.alma-env" >&2
  exit 1
fi

CHAR_COUNT=${#CONTENT}
echo "ALMA Send — $CHAR_COUNT chars"

if [ $DRY_RUN -eq 1 ]; then
  echo "[DRY RUN] Titulo: ${TITLE:-auto}"
  echo "[DRY RUN] Categoria: $CATEGORY"
  echo "[DRY RUN] Tags: ${TAGS:-auto}"
  echo "[DRY RUN] Source: $SOURCE"
  echo "[DRY RUN] Preview: ${CONTENT:0:200}..."
  exit 0
fi

# Step 1: Login
echo "Autenticando..."
LOGIN_RESPONSE=$(curl -s -X POST "$ALMA_URL/api/auth" \
  -H "Content-Type: application/json" \
  -d "{\"action\":\"login\",\"username\":\"$ALMA_USER\",\"password\":\"$ALMA_PASS\"}")

TOKEN=$(echo "$LOGIN_RESPONSE" | jq -r '.token // empty')

if [ -z "$TOKEN" ]; then
  ERROR=$(echo "$LOGIN_RESPONSE" | jq -r '.error // "Erro desconhecido"')
  echo "ERRO: Login falhou — $ERROR" >&2
  exit 1
fi

echo "OK — logado"

# Step 2: Build tags array
TAGS_JSON="[]"
if [ -n "$TAGS" ]; then
  TAGS_JSON=$(echo "$TAGS" | tr ',' '\n' | jq -R . | jq -s .)
fi

# Step 3: Send content
echo "Enviando..."

# Escape content for JSON
CONTENT_JSON=$(echo "$CONTENT" | jq -Rs .)
TITLE_JSON=$(echo "${TITLE:-}" | jq -Rs .)

INGEST_RESPONSE=$(curl -s -X POST "$ALMA_URL/api/ingest" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $TOKEN" \
  -d "{
    \"content\": $CONTENT_JSON,
    \"title\": $TITLE_JSON,
    \"category\": \"$CATEGORY\",
    \"tags\": $TAGS_JSON,
    \"source\": \"$SOURCE\"
  }")

SUCCESS=$(echo "$INGEST_RESPONSE" | jq -r '.success // empty')

if [ "$SUCCESS" = "true" ]; then
  CHUNKS=$(echo "$INGEST_RESPONSE" | jq -r '.chunks_created')
  TOTAL=$(echo "$INGEST_RESPONSE" | jq -r '.total_chars')
  SF=$(echo "$INGEST_RESPONSE" | jq -r '.source_file')
  echo ""
  echo "ALMA — Salvo!"
  echo "  Chunks: $CHUNKS"
  echo "  Chars: $TOTAL"
  echo "  Source: $SF"
  echo "  Categoria: $CATEGORY"
else
  ERROR=$(echo "$INGEST_RESPONSE" | jq -r '.error // "Erro desconhecido"')
  echo "ERRO: $ERROR" >&2
  exit 1
fi
