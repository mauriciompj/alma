# =============================================================================
# ALMA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit your .env file. It contains secrets.
# =============================================================================


# --- Database (Neon PostgreSQL) ---
# Get yours at: https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=


# --- AI (Anthropic Claude) ---
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# --- Google Sign-In — Optional ---
# For professional Google login, create a Web OAuth client in Google Cloud Console.
# Authorized JavaScript origins must include your site origin, e.g.:
#   https://projeto-alma.netlify.app
#   http://localhost:8888
# Authorized redirect URIs are not required for the popup-based GIS flow below.
GOOGLE_CLIENT_ID=

# Optional: restrict Google login to a Workspace domain (example: empresa.com.br)
GOOGLE_HOSTED_DOMAIN=


# --- Search Language (PostgreSQL full-text search) — Optional ---
# Controls stemming and stop-word rules for memory search.
# Options: 'simple' (universal default), 'portuguese', 'english', 'spanish', etc.
# IMPORTANT: Must match the language used in to_tsvector() when inserting chunks.
# If your memories are in Portuguese, set to 'portuguese' for better stemming.
SEARCH_LANGUAGE=simple


# --- Voice (ElevenLabs TTS) — Optional ---
# Enables voice playback in chat (hear ALMA speak)
# Get yours at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


# --- Optional: Netlify-specific ---
# When deploying to Netlify, the platform may inject this automatically.
# If set, it takes priority over DATABASE_URL.
# NETLIFY_DATABASE_URL=

