# =============================================================================
# ALMA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit your .env file. It contains secrets.
# =============================================================================


# --- Database (Neon PostgreSQL) ---
# Get yours at: https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=


# --- AI (Anthropic Claude) ---
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# --- Voice (ElevenLabs) — Optional ---
# If not set, voice features are hidden automatically (graceful degradation).
# Get yours at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2


# --- CORS Origin — Optional ---
# Restricts API access to this domain only. Defaults to your Netlify URL.
# Set this if using a custom domain.
# ALLOWED_ORIGIN=https://your-site.netlify.app

# --- Optional: Netlify-specific ---
# When deploying to Netlify, the platform may inject this automatically.
# If set, it takes priority over DATABASE_URL.
# NETLIFY_DATABASE_URL=

