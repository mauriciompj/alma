{
  "name": "alma-app",
  "version": "4.0.0",
  "description": "ALMA — A Voz do Pai. Sistema de legado emocional paternal com RAG + Neon DB.",
  "private": true,
  "scripts": {
    "dev": "netlify dev",
    "build": "echo 'Static site — no build step needed'",
    "seed": "node db/run-seed.mjs",
    "seed:demo": "node db/run-seed-demo.mjs",
    "backup": "node db/backup.mjs",
    "test": "npm run test:integration:demo",
    "test:integration": "node tests/auth.test.mjs",
    "test:integration:demo": "node tests/auth.test.mjs",
    "test:integration:prod": "node -e \"process.env.TEST_URL='https://projeto-alma.netlify.app'; import('./tests/auth.test.mjs')\"",
    "test:deep": "node tests/deep-test.mjs",
    "test:deep:prod": "node -e \"process.env.TEST_URL='https://projeto-alma.netlify.app'; import('./tests/deep-test.mjs')\"",
    "test:unit": "node tests/unit-test.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@sentry/node": "^10.46.0",
    "bcryptjs": "^2.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1"
  }
}
